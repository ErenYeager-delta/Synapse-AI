# ════════════════════════════════════════════════════════
#  Synapse AI — Environment Variables
#  Step 1: Copy this file → rename it to just ".env"
#  Step 2: Replace EVERY value below with your real values
# ════════════════════════════════════════════════════════

# Django secret key — any long random string is fine
SECRET_KEY=django-insecure-change-this-to-any-random-string-123456789

# Keep True for local development
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# ── MongoDB Atlas ─────────────────────────────────────
# HOW TO GET THIS:
#  1. Go to https://cloud.mongodb.com
#  2. Click your Cluster → "Connect" → "Connect your application"
#  3. Copy the connection string — replace <username> and <password>
#  Example: mongodb+srv://vignesh:mypassword@cluster0.abcde.mongodb.net/synapse_mongo
MONGO_URI=mongodb+srv://Web_App_for_Product_finder:Vikky2000@cluster0.fsmvz1q.mongodb.net/?appName=Cluster0

# ── Google Gemini API Key ─────────────────────────────
# HOW TO GET THIS:
#  1. Go to https://aistudio.google.com
#  2. Click "Get API Key" → Create API key
#  3. Copy and paste it below
# Primary key for LLM
GEMINI_API_KEY=AIzaSyDP78u4EpQxV2i-ePY9WFwbQEguKhcPosA
# Optional rotation pool (comma-separated)
GEMINI_API_KEYS=AIzaSyAE5UtKH9yGMbCjASEmwxTHwanPvb6jBjk

# ── EmailJS (for OTP emails) ──────────────────────────
# HOW TO GET THIS:
#  1. Go to https://dashboard.emailjs.com/admin
#  2. Add Email Service → copy Service ID
#  3. Create Email Template → copy Template ID
#  4. Go to Account → copy Public Key
EMAILJS_SERVICE_ID=service_jpg03s7
EMAILJS_TEMPLATE_ID=template_n319w4a
EMAILJS_PUBLIC_KEY=KF70fTzyyxd3aje3B

# ── Redis (OPTIONAL — app works without it) ───────────
# Leave this commented out. App auto-falls back to memory cache.
# REDIS_URL=redis://127.0.0.1:6379/0
